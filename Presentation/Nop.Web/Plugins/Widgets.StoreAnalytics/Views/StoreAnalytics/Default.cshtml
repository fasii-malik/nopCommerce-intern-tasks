@model Nop.Plugin.Widgets.StoreAnalytics.Models.StoreAnalyticsModel

<div class="store-analytics-widget">
    <div class="analytics-header">
        <i class="fas fa-chart-line"></i>
        <span>Store Analytics — Today</span>
    </div>

    <div class="analytics-cards">

        @*-- Card 1: Total Orders Today --*@
        <div class="analytics-card orders">
            <div class="card-icon">
                <i class="fas fa-shopping-cart"></i>
            </div>
            <div class="card-body">
                <div class="card-value">@Model.TotalOrdersToday</div>
                <div class="card-label">Orders Today</div>
            </div>
        </div>

        @*-- Card 2: Total Revenue Today --*@
        <div class="analytics-card revenue">
            <div class="card-icon">
                <i class="fas fa-dollar-sign"></i>
            </div>
            <div class="card-body">
                <div class="card-value">$@Model.TotalRevenueToday.ToString("N2")</div>
                <div class="card-label">Revenue Today</div>
            </div>
        </div>

        @*-- Card 3: New Customers Today --*@
        <div class="analytics-card customers">
            <div class="card-icon">
                <i class="fas fa-user-plus"></i>
            </div>
            <div class="card-body">
                <div class="card-value">@Model.NewCustomersToday</div>
                <div class="card-label">New Customers</div>
            </div>
        </div>

        @*-- Card 4: Top Selling Product --*@
        <div class="analytics-card top-product">
            <div class="card-icon">
                <i class="fas fa-trophy"></i>
            </div>
            <div class="card-body">
                <div class="card-value top-product-name" title="@Model.TopSellingProductName">
                    @Model.TopSellingProductName
                </div>
                <div class="card-label">Top Product (@Model.TopSellingProductQuantity sold)</div>
            </div>
        </div>

    </div>
</div>

<style>
    .store-analytics-widget {
        margin: 0 0 20px 0;
        font-family: 'Segoe UI', sans-serif;
    }

    .analytics-header {
        font-size: 15px;
        font-weight: 600;
        color: #555;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .analytics-cards {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .analytics-card {
        flex: 1;
        min-width: 180px;
        border-radius: 8px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        color: #fff;
        box-shadow: 0 2px 6px rgba(0,0,0,0.12);
    }

    .analytics-card.orders    { background: linear-gradient(135deg, #4e73df, #375ac8); }
    .analytics-card.revenue   { background: linear-gradient(135deg, #1cc88a, #13a673); }
    .analytics-card.customers { background: linear-gradient(135deg, #36b9cc, #1a9aaa); }
    .analytics-card.top-product { background: linear-gradient(135deg, #f6c23e, #d4a20a); }

    .card-icon {
        font-size: 28px;
        opacity: 0.85;
    }

    .card-value {
        font-size: 22px;
        font-weight: 700;
        line-height: 1.2;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 180px;
    }

    .card-label {
        font-size: 12px;
        opacity: 0.9;
        margin-top: 4px;
    }

    .top-product-name {
        font-size: 16px;
    }
</style>
