@model Nop.Plugin.Payments.Stripe.Models.PaymentInfoModel

<style>
    #stripe-payment-wrapper {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 15px;
    }

        #stripe-payment-wrapper label {
            font-weight: 600;
            font-size: 14px;
            color: #424770;
            margin-bottom: 8px;
            display: block;
        }

    #stripe-card-element {
        padding: 12px;
        border: 1px solid #ccc;
        border-radius: 6px;
        background: white;
        min-height: 44px;
        transition: border-color 0.2s;
    }

        #stripe-card-element.focused {
            border-color: #6772e5;
            box-shadow: 0 0 0 3px rgba(103, 114, 229, 0.15);
        }

    #stripe-card-errors {
        color: #dc3545;
        margin-top: 8px;
        font-size: 13px;
        min-height: 18px;
    }

    /* ── Loading overlay ── */
    #stripe-loading-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.85);
        z-index: 99999;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
    }

        #stripe-loading-overlay.visible {
            display: flex;
        }

    .stripe-spinner {
        width: 44px;
        height: 44px;
        border: 4px solid #e0e0e0;
        border-top-color: #6772e5;
        border-radius: 50%;
        animation: stripe-spin 0.75s linear infinite;
    }

    .stripe-loading-text {
        font-size: 15px;
        font-weight: 500;
        color: #424770;
        letter-spacing: 0.3px;
    }

    .stripe-loading-sub {
        font-size: 12px;
        color: #8898aa;
        margin-top: -10px;
    }

    @@keyframes stripe-spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* ── Secure badge ── */
    .stripe-secure-badge {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 10px;
        font-size: 12px;
        color: #8898aa;
    }

        .stripe-secure-badge svg {
            flex-shrink: 0;
        }
</style>

<!-- Loading overlay (full page) -->
<div id="stripe-loading-overlay">
    <div class="stripe-spinner"></div>
    <div class="stripe-loading-text" id="stripe-loading-text">Processing payment...</div>
    <div class="stripe-loading-sub">Please do not close or refresh this page</div>
</div>

<!-- Card UI -->
<div id="stripe-payment-wrapper">
    <label>Card Details</label>

    <div id="stripe-card-element"></div>
    <div id="stripe-card-errors"></div>

    <div class="stripe-secure-badge">
        <svg width="12" height="14" viewBox="0 0 12 14" fill="none"
             xmlns="http://www.w3.org/2000/svg">
            <path d="M6 0L0 2.5V6.5C0 9.8 2.58 12.9 6 14C9.42 12.9 12 9.8 12 6.5V2.5L6 0Z"
                  fill="#8898aa" />
        </svg>
        Secured by Stripe — your card details are encrypted
    </div>
</div>

<input type="hidden" name="StripePaymentMethodId" id="StripePaymentMethodId" value="" />

<script>
    (function () {
        // ── Helpers ───────────────────────────────────────────────────────────
        function showLoading(message) {
            document.getElementById('stripe-loading-text').textContent =
                message || 'Processing payment...';
            document.getElementById('stripe-loading-overlay').classList.add('visible');
        }

        function hideLoading() {
            document.getElementById('stripe-loading-overlay').classList.remove('visible');
        }

        function showError(message) {
            document.getElementById('stripe-card-errors').textContent = message || '';
            hideLoading();
        }

        // ── Load Stripe.js ────────────────────────────────────────────────────
        function loadStripe(callback) {
            if (window.Stripe) { callback(); return; }
            var script = document.createElement('script');
            script.src = 'https://js.stripe.com/v3/';
            script.onload = callback;
            script.onerror = function () {
                showError('Failed to load Stripe. Please refresh the page.');
            };
            document.head.appendChild(script);
        }

        loadStripe(function () {
            var stripe = Stripe('@Model.PublishableKey');
            var elements = stripe.elements();

            var cardElement = elements.create('card', {
                hidePostalCode: true,
                style: {
                    base: {
                        fontSize: '16px',
                        color: '#32325d',
                        fontFamily: '"Helvetica Neue", Helvetica, sans-serif',
                        '::placeholder': { color: '#aab7c4' }
                    },
                    invalid: { color: '#dc3545' }
                }
            });

            cardElement.mount('#stripe-card-element');

            // Focus styling
            cardElement.on('focus', function () {
                document.getElementById('stripe-card-element').classList.add('focused');
            });
            cardElement.on('blur', function () {
                document.getElementById('stripe-card-element').classList.remove('focused');
            });

            // Real-time validation errors
            cardElement.on('change', function (e) {
                document.getElementById('stripe-card-errors').textContent =
                    e.error ? e.error.message : '';
            });

            // ── Intercept jQuery AJAX ─────────────────────────────────────────
            var originalAjax = $.ajax.bind($);

            $.ajax = function (settings) {
                if (typeof settings === 'string') {
                    settings = arguments[1] || {};
                    settings.url = arguments[0];
                }

                var url = (settings.url || '').toLowerCase();

                if (url.indexOf('opcsavepaymentinfo') !== -1) {
                    console.log('[Stripe] Intercepted OpcSavePaymentInfo call');

                    var existingId = document.getElementById('StripePaymentMethodId').value;

                    if (existingId) {
                        console.log('[Stripe] Already have PaymentMethodId, proceeding');
                        if (typeof settings.data === 'string') {
                            settings.data += '&StripePaymentMethodId=' + existingId;
                        } else {
                            settings.data = settings.data || {};
                            settings.data.StripePaymentMethodId = existingId;
                        }
                        return originalAjax(settings);
                    }

                    // Show loading while Stripe creates the payment method
                    showLoading('Validating card details...');

                    stripe.createPaymentMethod({
                        type: 'card',
                        card: cardElement
                    }).then(function (result) {
                        if (result.error) {
                            showError(result.error.message);
                            var btn = document.querySelector('.payment-info-next-step-button');
                            if (btn) btn.disabled = false;
                            return;
                        }

                        console.log('[Stripe] PaymentMethod:', result.paymentMethod.id);

                        document.getElementById('StripePaymentMethodId').value =
                            result.paymentMethod.id;

                        // Update loading message before firing the AJAX call
                        showLoading('Confirming payment...');

                        if (typeof settings.data === 'string') {
                            settings.data += '&StripePaymentMethodId=' + result.paymentMethod.id;
                        } else {
                            settings.data = settings.data || {};
                            settings.data.StripePaymentMethodId = result.paymentMethod.id;
                        }

                        // Wrap success to hide loader when NopCommerce responds
                        var originalSuccess = settings.success;
                        settings.success = function (response) {
                            hideLoading();
                            if (originalSuccess) originalSuccess(response);
                        };

                        var originalError = settings.error;
                        settings.error = function (xhr) {
                            showError('Payment failed. Please try again.');
                            var btn = document.querySelector('.payment-info-next-step-button');
                            if (btn) btn.disabled = false;
                            if (originalError) originalError(xhr);
                        };

                        return originalAjax(settings);

                    }).catch(function (err) {
                        showError('Stripe error: ' + err.message);
                        var btn = document.querySelector('.payment-info-next-step-button');
                        if (btn) btn.disabled = false;
                    });

                    return $.Deferred().promise();
                }

                return originalAjax(settings);
            };

            console.log('[Stripe] jQuery AJAX interceptor installed');
        });
    })();
</script>