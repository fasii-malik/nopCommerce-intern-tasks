<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Lato:wght@300;400&display=swap" rel="stylesheet" />

<style>

    .welcome-banner {
        position: relative;
        width: 100%;
        min-height: 380px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        margin-bottom: 30px;
    }

    .welcome-banner::before {
        content: '';
        position: absolute;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(255,200,100,0.15) 0%, transparent 70%);
        top: -100px;
        left: -100px;
        border-radius: 50%;
        animation: pulse 6s ease-in-out infinite;
    }

    .welcome-banner::after {
        content: '';
        position: absolute;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(100,180,255,0.12) 0%, transparent 70%);
        bottom: -80px;
        right: -60px;
        border-radius: 50%;
        animation: pulse 8s ease-in-out infinite reverse;
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.2); opacity: 0.7; }
    }

    .banner-content {
        position: relative;
        z-index: 2;
        text-align: center;
        padding: 60px 40px;
        max-width: 800px;
    }

    .banner-eyebrow {
        font-family: 'Lato', sans-serif;
        font-weight: 300;
        font-size: 13px;
        letter-spacing: 6px;
        text-transform: uppercase;
        color: #f0c040;
        margin-bottom: 20px;
        opacity: 0;
        animation: fadeUp 0.8s ease forwards 0.2s;
    }

    .banner-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.2rem, 5vw, 4rem);
        font-weight: 900;
        color: #ffffff;
        line-height: 1.15;
        margin-bottom: 20px;
        opacity: 0;
        animation: fadeUp 0.8s ease forwards 0.4s;
    }

    .banner-title span {
        background: linear-gradient(90deg, #f0c040, #ff8c69);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .banner-subtitle {
        font-family: 'Lato', sans-serif;
        font-size: 1.1rem;
        font-weight: 300;
        color: rgba(255,255,255,0.7);
        line-height: 1.7;
        max-width: 550px;
        margin: 0 auto 35px;
        opacity: 0;
        animation: fadeUp 0.8s ease forwards 0.6s;
    }

    .banner-btn {
        display: inline-block;
        padding: 14px 40px;
        background: linear-gradient(90deg, #f0c040, #ff8c69);
        color: #1a1a2e;
        font-family: 'Lato', sans-serif;
        font-weight: 700;
        font-size: 14px;
        letter-spacing: 2px;
        text-transform: uppercase;
        text-decoration: none;
        border-radius: 50px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        opacity: 0;
        animation: fadeUp 0.8s ease forwards 0.8s;
    }

    .banner-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(240,192,64,0.4);
        text-decoration: none;
        color: #1a1a2e;
    }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(25px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="welcome-banner">
    <div class="banner-content">
        <p class="banner-eyebrow">✦ Welcome to Our Store ✦</p>
        <h1 class="banner-title">
            Discover Products <span>You'll Love</span>
        </h1>
        <p class="banner-subtitle">
            Explore our handpicked collection of premium products — crafted for quality, delivered with care.
        </p>
        <a href="/" class="banner-btn">Shop Now</a>
    </div>
</div>